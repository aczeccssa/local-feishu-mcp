# 飞书应用凭证
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 传输模式: http 或 stdio
MCP_TRANSPORT=http

# HTTP监听地址（默认仅绑定本机回环地址）
HOST=127.0.0.1
PORT=7777

# 可选：HTTP访问令牌。设置后，/mcp 需要 Bearer Token
# 或 ?token=... 才能建立SSE会话
MCP_AUTH_TOKEN=replace_with_a_strong_random_token

# 可选：额外允许的Host头，多个值用逗号分隔
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# 可选：HTTP请求安全限制
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120
MCP_REQUEST_TIMEOUT_MS=30000
